# Local AI / editor config (machine-specific; do not commit secrets)
.claude/settings.local.json

# Docx files (keep locally, don't track in git)
*.docx

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase configuration (contains API keys)
lib/firebase_options.dart

# Test and temporary files
*.txt
test_machine*.json
test_utf8*.json
*.bat
*.ps1

# Screenshot files
*.png

# Temporary JSON files
bonus_questions.json
extract_docx.py
merge_questions.py
parse_*.py
